@inherits LayoutComponentBase

<style>
    /* CSS pentru așezarea în pagină (Layout) */
    .app-container {
        display: flex;
        height: 100vh; /* Ocupă tot ecranul pe înălțime */
        font-family: Arial, sans-serif;
    }

    .sidebar {
        width: 250px;
        background-color: #2c3e50;
        color: white;
        padding: 20px;
        display: flex;
        flex-direction: column;
        gap: 15px;
    }

    /* Am adăugat puțin CSS pentru căsuța de căutare */
    .search-box {
        width: 100%;
        padding: 8px;
        border: none;
        border-radius: 3px;
        font-size: 14px;
        box-sizing: border-box; /* Asigură că padding-ul nu depășește lățimea */
    }

    .btn-meniu {
        background-color: #34495e;
        color: white;
        border: 1px solid #1abc9c;
        padding: 10px;
        text-align: left;
        cursor: pointer;
        font-size: 16px;
        border-radius: 5px;
    }
    .btn-meniu:hover { background-color: #1abc9c; }

    .main-area {
        flex-grow: 1;
        display: flex;
        flex-direction: column;
        background-color: #f4f6f8;
    }

    .top-header {
        height: 60px;
        background-color: white;
        border-bottom: 1px solid #ddd;
        display: flex;
        justify-content: flex-end; /* Împinge elementele la dreapta */
        align-items: center;
        padding: 0 20px;
    }

    /* Am actualizat CSS-ul pentru a face poza utilizatorului rotundă */
    .user-profile-img {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        object-fit: cover; /* Asigură că poza nu se distorsionează */
        border: 2px solid #ddd;
    }

    .content {
        padding: 20px;
        overflow-y: auto;
    }
</style>

<div class="app-container">
    
    <div class="sidebar">
        <img src="/images/logo.png" alt="Siglă Velox" style="max-height: 60px; object-fit: contain; margin-bottom: 10px;" />
        
        <input type="text" class="search-box" placeholder="Caută VID / ID..." />

        <hr style="width: 100%; border-color: gray;" />
        
        <button class="btn-meniu">FILTRE</button>
        <button class="btn-meniu">LIVRĂRI</button>
    </div>

    <div class="main-area">
        
        <div class="top-header">
            <img src="/images/user.jpg" alt="Utilizator" class="user-profile-img" />
        </div>
        
        <div class="content">
            @Body
        </div>

    </div>
</div>